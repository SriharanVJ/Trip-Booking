// Prisma Schema for Vehicle Booking Application
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum VehicleType {
  CAR_5_SEATER
  CAR_7_SEATER
  CAR_9_SEATER
  TRAVELLER_14_SEATER
  COACH_21_SEATER
  COACH_24_SEATER
  BUS_52_SEATER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIAL
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
  MULTI_CITY
}

enum Amenities {
  AC
  NON_AC
  WIFI
  USB_CHARGING
  ENTERTAINMENT_SYSTEM
  GPS
  FIRST_AID_KIT
  FIRE_EXTINGUISHER
  REFRIGERATOR
  RECLINING_SEATS
  PUSHBACK_SEATS
  READING_LIGHTS
  BLANKETS
  PILLOWS
  WATER_BOTTLES
  SNACKS
  LUGGAGE_SPACE
  HANDICAP_ACCESSIBLE
  PASSENGER_DISPLAY
  MICROPHONE
}

// ============================================================================
// MODELS
// ============================================================================

/// Vehicle fleet with various seating capacities and amenities
model Vehicle {
  id                    String                @id @default(uuid())
  registrationNumber    String                @unique
  name                  String
  type                  VehicleType
  seatingCapacity       Int
  isAvailable           Boolean               @default(true)
  pricePerKm            Decimal               @db.Decimal(10, 2)
  minimumCharge         Decimal               @db.Decimal(10, 2)
  driverAllowancePerDay Decimal               @db.Decimal(10, 2)
  minimumDays           Int                   @default(1)
  make                  String?
  model                 String?
  year                  Int?
  fuelType              String?
  color                 String?
  amenities             Amenities[]
  images                String[]
  thumbnailImage        String?
  description           String?               @db.Text
  features              String?               @db.Text
  lastServiceDate       DateTime?
  nextServiceDue        DateTime?
  insuranceExpiry       DateTime?
  pollutionCertExpiry   DateTime?
  fitnessCertExpiry     DateTime?
  rating                Decimal               @default(0) @db.Decimal(3, 2)
  reviewCount           Int                   @default(0)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  bookings              Booking[]
  maintenanceLogs       MaintenanceLog[]
  availabilities        VehicleAvailability[]

  @@map("vehicles")
}

/// Customer details for bookings
model Customer {
  id             String    @id @default(uuid())
  firstName      String
  lastName       String
  email          String    @unique
  phone          String
  alternatePhone String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  country        String    @default("India")
  idType         String?
  idNumber       String?
  idProofUrl     String?
  companyName    String?
  companyGst     String?
  companyAddress String?   @db.Text
  passwordHash   String?
  isVerified     Boolean   @default(false)
  isCorporate    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastLoginAt    DateTime?
  bookings       Booking[]
  payments       Payment[]

  @@map("customers")
}

/// Booking details for trips
model Booking {
  id                     String        @id @default(uuid())
  bookingNumber          String        @unique
  customerId             String
  customer               Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleId              String
  vehicle                Vehicle       @relation(fields: [vehicleId], references: [id])
  driverId               String?
  tripType               TripType
  startDate              DateTime
  endDate                DateTime?
  pickupLocation         String        @db.Text
  pickupLandmark         String?
  pickupLat              Decimal?      @db.Decimal(10, 8)
  pickupLng              Decimal?      @db.Decimal(11, 8)
  pickupTime             DateTime
  dropLocation           String        @db.Text
  dropLandmark           String?
  dropLat                Decimal?      @db.Decimal(10, 8)
  dropLng                Decimal?      @db.Decimal(11, 8)
  returnPickupLocation   String?       @db.Text
  returnDropLocation     String?       @db.Text
  returnPickupTime       DateTime?
  multiCityStops         String?       @db.Text
  estimatedDistanceKm    Decimal?      @db.Decimal(10, 2)
  estimatedDurationHours Decimal?      @db.Decimal(10, 2)
  passengerCount         Int           @default(1)
  baseFare               Decimal       @db.Decimal(10, 2)
  distanceCharge         Decimal       @default(0) @db.Decimal(10, 2)
  driverAllowance        Decimal       @default(0) @db.Decimal(10, 2)
  tollCharges            Decimal       @default(0) @db.Decimal(10, 2)
  parkingCharges         Decimal       @default(0) @db.Decimal(10, 2)
  nightHaltCharges       Decimal       @default(0) @db.Decimal(10, 2)
  serviceTax             Decimal       @default(0) @db.Decimal(10, 2)
  discount               Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount            Decimal       @db.Decimal(10, 2)
  advancePaid            Decimal       @default(0) @db.Decimal(10, 2)
  balanceAmount          Decimal       @db.Decimal(10, 2)
  status                 BookingStatus @default(PENDING)
  paymentStatus          PaymentStatus @default(PENDING)
  specialRequests        String?       @db.Text
  notes                  String?       @db.Text
  cancellationReason     String?       @db.Text
  cancelledAt            DateTime?
  cancelledBy            String?
  driverName             String?
  driverPhone            String?
  paymentDueAmount       Decimal       @db.Decimal(10, 2)
  paymentDueDate         DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  confirmedAt            DateTime?
  completedAt            DateTime?
  payments               Payment[]

  @@map("bookings")
}

/// Payment transactions
model Payment {
  id                   String        @id @default(uuid())
  transactionId        String        @unique
  bookingId            String
  booking              Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerId           String
  customer             Customer      @relation(fields: [customerId], references: [id])
  amount               Decimal       @db.Decimal(10, 2)
  paymentMethod        PaymentMethod
  status               PaymentStatus @default(PENDING)
  transactionDate      DateTime      @default(now())
  transactionRef       String?
  gatewayName          String?
  gatewayTransactionId String?
  gatewayResponse      String?       @db.Text
  refundAmount         Decimal?      @db.Decimal(10, 2)
  refundReason         String?
  refundDate           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  completedAt          DateTime?
  notes                String?       @db.Text

  @@map("payments")
}

/// Admin users for dashboard access
model Admin {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  username     String?       @unique
  firstName    String
  lastName     String
  phone        String?
  role         String        @default("ADMIN")
  permissions  String[]      @default([])
  isActive     Boolean       @default(true)
  isSuperAdmin Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  lastLoginAt  DateTime?
  lastLoginIp  String?
  activityLogs ActivityLog[]

  @@map("admins")
}

/// Activity logs for admin actions
model ActivityLog {
  id          String   @id @default(uuid())
  adminId     String
  admin       Admin    @relation(fields: [adminId], references: [id])
  action      String
  entity      String
  entityId    String?
  description String   @db.Text
  ipAddress   String?
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())

  @@map("activity_logs")
}

/// Vehicle availability calendar for optimization
model VehicleAvailability {
  id                String   @id @default(uuid())
  vehicleId         String
  vehicle           Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date              DateTime
  startTime         String
  endTime           String
  isAvailable       Boolean  @default(true)
  bookingId         String?
  currentLocation   String?
  currentLat        Decimal? @db.Decimal(10, 8)
  currentLng        Decimal? @db.Decimal(11, 8)
  isMaintenance     Boolean  @default(false)
  maintenanceReason String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([vehicleId, date, startTime])
  @@map("vehicle_availabilities")
}

/// Maintenance logs for vehicles
model MaintenanceLog {
  id                   String    @id @default(uuid())
  vehicleId            String
  vehicle              Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type                 String
  description          String    @db.Text
  cost                 Decimal?  @db.Decimal(10, 2)
  startDate            DateTime  @default(now())
  endDate              DateTime?
  completedAt          DateTime?
  serviceProvider      String?
  serviceProviderPhone String?
  invoiceNumber        String?
  status               String    @default("PENDING")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  performedBy          String?

  @@map("maintenance_logs")
}

/// Configuration and settings
model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  description String?  @db.Text
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

/// Promo codes and discounts
model PromoCode {
  id                     String           @id @default(uuid())
  code                   String           @unique
  description            String?
  discountType           String
  discountValue          Decimal          @db.Decimal(10, 2)
  maxDiscountAmount      Decimal?         @db.Decimal(10, 2)
  minBookingAmount       Decimal?         @db.Decimal(10, 2)
  applicableVehicleTypes String[]
  applicableTripTypes    String[]
  startDate              DateTime
  endDate                DateTime
  maxUses                Int?
  usedCount              Int              @default(0)
  maxUsesPerUser         Int?
  isActive               Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  usages                 PromoCodeUsage[]

  @@map("promo_codes")
}

/// Promo code usage tracking
model PromoCodeUsage {
  id              String    @id @default(uuid())
  promoCodeId     String
  promoCode       PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  bookingId       String
  customerId      String
  discountApplied Decimal   @db.Decimal(10, 2)
  createdAt       DateTime  @default(now())

  @@unique([promoCodeId, bookingId])
  @@map("promo_code_usages")
}
