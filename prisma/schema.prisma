// Prisma Schema for Vehicle Booking Application
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum VehicleType {
  CAR_5_SEATER
  CAR_7_SEATER
  CAR_9_SEATER
  TRAVELLER_14_SEATER
  COACH_21_SEATER
  COACH_24_SEATER
  BUS_52_SEATER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIAL
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
  MULTI_CITY
}

enum Amenities {
  AC
  NON_AC
  WIFI
  USB_CHARGING
  ENTERTAINMENT_SYSTEM
  GPS
  FIRST_AID_KIT
  FIRE_EXTINGUISHER
  REFRIGERATOR
  RECLINING_SEATS
  PUSHBACK_SEATS
  READING_LIGHTS
  BLANKETS
  PILLOWS
  WATER_BOTTLES
  SNACKS
  LUGGAGE_SPACE
  HANDICAP_ACCESSIBLE
  PASSENGER_DISPLAY
  MICROPHONE
}

// ============================================================================
// MODELS
// ============================================================================

/// Vehicle fleet with various seating capacities and amenities
model Vehicle {
  id                String         @id @default(uuid())
  registrationNumber String         @unique
  name              String
  type              VehicleType
  seatingCapacity   Int
  isAvailable       Boolean        @default(true)

  // Pricing structure (in INR)
  pricePerKm        Decimal        @db.Decimal(10, 2)
  minimumCharge     Decimal        @db.Decimal(10, 2)
  driverAllowancePerDay Decimal    @db.Decimal(10, 2)
  minimumDays       Int            @default(1)

  // Vehicle details
  make              String?
  model             String?
  year              Int?
  fuelType          String?        // PETROL, DIESEL, CNG, ELECTRIC
  color             String?

  // Amenities available
  amenities         Amenities[]

  // Images (stored as comma-separated URLs or JSON)
  images            String[]
  thumbnailImage    String?

  // Additional details
  description       String?        @db.Text
  features          String?        @db.Text  // JSON for additional features

  // Maintenance
  lastServiceDate   DateTime?
  nextServiceDue    DateTime?
  insuranceExpiry   DateTime?
  pollutionCertExpiry DateTime?
  fitnessCertExpiry DateTime?

  // Rating and reviews
  rating            Decimal        @default(0) @db.Decimal(3, 2)
  reviewCount       Int            @default(0)

  // Timestamps
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relations
  bookings          Booking[]
  availabilities    VehicleAvailability[]
  maintenanceLogs   MaintenanceLog[]
}

/// Customer details for bookings
model Customer {
  id                String         @id @default(uuid())

  // Personal information
  firstName         String
  lastName          String
  email             String         @unique
  phone             String
  alternatePhone    String?

  // Address
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  postalCode        String?
  country           String         @default("India")

  // KYC details (optional for corporate bookings)
  idType            String?        // AADHAR, PASSPORT, DRIVING_LICENSE, PAN
  idNumber          String?
  idProofUrl        String?

  // Company details for corporate bookings
  companyName       String?
  companyGst        String?
  companyAddress    String?        @db.Text

  // Authentication
  passwordHash      String?
  isVerified        Boolean        @default(false)
  isCorporate       Boolean        @default(false)

  // Timestamps
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  lastLoginAt       DateTime?

  // Relations
  bookings          Booking[]
  payments          Payment[]
}

/// Booking details for trips
model Booking {
  id                String         @id @default(uuid())
  bookingNumber     String         @unique

  // Relations
  customerId        String
  customer          Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleId         String
  vehicle           Vehicle        @relation(fields: [vehicleId], references: [id])
  driverId          String?        // Can link to Driver model if needed

  // Trip details
  tripType          TripType
  startDate         DateTime
  endDate           DateTime?

  // Route details (stored as JSON for flexibility)
  pickupLocation    String         @db.Text
  pickupLandmark    String?
  pickupLat         Decimal?       @db.Decimal(10, 8)
  pickupLng         Decimal?       @db.Decimal(11, 8)
  pickupTime        DateTime

  dropLocation      String         @db.Text
  dropLandmark      String?
  dropLat           Decimal?       @db.Decimal(10, 8)
  dropLng           Decimal?       @db.Decimal(11, 8)

  // For round-trip and multi-city
  returnPickupLocation String?     @db.Text
  returnDropLocation  String?      @db.Text
  returnPickupTime    DateTime?

  // Multi-city stops (JSON array of stops)
  multiCityStops     String?        @db.Text  // JSON: [{location, landmark, lat, lng, time}]

  // Distance and duration estimates
  estimatedDistanceKm Decimal?
  estimatedDurationHours Decimal?

  // Passenger count
  passengerCount    Int            @default(1)

  // Pricing details (in INR)
  baseFare          Decimal        @db.Decimal(10, 2)
  distanceCharge    Decimal        @default(0) @db.Decimal(10, 2)
  driverAllowance   Decimal        @default(0) @db.Decimal(10, 2)
  tollCharges       Decimal        @default(0) @db.Decimal(10, 2)
  parkingCharges    Decimal        @default(0) @db.Decimal(10, 2)
  nightHaltCharges  Decimal        @default(0) @db.Decimal(10, 2)
  serviceTax        Decimal        @default(0) @db.Decimal(10, 2)
  discount          Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount       Decimal        @db.Decimal(10, 2)
  advancePaid       Decimal        @default(0) @db.Decimal(10, 2)
  balanceAmount     Decimal        @db.Decimal(10, 2)

  // Booking status
  status            BookingStatus  @default(PENDING)
  paymentStatus     PaymentStatus  @default(PENDING)

  // Additional details
  specialRequests   String?        @db.Text
  notes             String?        @db.Text
  cancellationReason String?       @db.Text
  cancelledAt       DateTime?
  cancelledBy       String?        // CUSTOMER, ADMIN, SYSTEM

  // Driver details (assigned driver)
  driverName        String?
  driverPhone       String?

  // Payment tracking
  paymentDueAmount  Decimal        @db.Decimal(10, 2)
  paymentDueDate    DateTime?

  // Timestamps
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  confirmedAt       DateTime?
  completedAt       DateTime?

  // Relations
  payments          Payment[]
}

/// Payment transactions
model Payment {
  id                String         @id @default(uuid())
  transactionId     String         @unique

  // Relations
  bookingId         String
  booking           Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerId        String
  customer          Customer       @relation(fields: [customerId], references: [id])

  // Payment details
  amount            Decimal        @db.Decimal(10, 2)
  paymentMethod     PaymentMethod
  status            PaymentStatus  @default(PENDING)

  // Transaction details
  transactionDate   DateTime       @default(now())
  transactionRef    String?        // Bank reference, UPI ref, etc.

  // Gateway details (if using payment gateway)
  gatewayName       String?        // RAZORPAY, STRIPE, PAYTM, etc.
  gatewayTransactionId String?
  gatewayResponse   String?        @db.Text  // JSON response

  // Refund details
  refundAmount      Decimal?       @db.Decimal(10, 2)
  refundReason      String?
  refundDate        DateTime?

  // Timestamps
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  completedAt       DateTime?

  // Additional info
  notes             String?        @db.Text
}

/// Admin users for dashboard access
model Admin {
  id                String         @id @default(uuid())

  // Credentials
  email             String         @unique
  passwordHash      String
  username          String?        @unique

  // Personal info
  firstName         String
  lastName          String
  phone             String?

  // Role and permissions
  role              String         @default("ADMIN") // ADMIN, SUPER_ADMIN, STAFF
  permissions       String[]       @default([])     // Array of permission strings

  // Status
  isActive          Boolean        @default(true)
  isSuperAdmin      Boolean        @default(false)

  // Timestamps
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  lastLoginAt       DateTime?
  lastLoginIp       String?

  // Activity logs
  activityLogs      ActivityLog[]
}

/// Activity logs for admin actions
model ActivityLog {
  id                String         @id @default(uuid())

  adminId           String
  admin             Admin          @relation(fields: [adminId], references: [id])

  action            String         // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, etc.
  entity            String         // BOOKING, VEHICLE, CUSTOMER, etc.
  entityId          String?
  description       String         @db.Text

  // Request details
  ipAddress         String?
  userAgent         String?        @db.Text

  // Timestamp
  createdAt         DateTime       @default(now())
}

/// Vehicle availability calendar for optimization
model VehicleAvailability {
  id                String         @id @default(uuid())

  vehicleId         String
  vehicle           Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  // Date range
  date              DateTime
  startTime         String         // HH:MM format
  endTime           String         // HH:MM format

  // Availability status
  isAvailable       Boolean        @default(true)

  // Booking details (if booked)
  bookingId         String?        // Reference to booking if booked

  // Location details (for vehicle positioning)
  currentLocation   String?
  currentLat        Decimal?       @db.Decimal(10, 8)
  currentLng        Decimal?       @db.Decimal(11, 8)

  // Maintenance block
  isMaintenance     Boolean        @default(false)
  maintenanceReason String?

  // Timestamps
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Unique constraint
  @@unique([vehicleId, date, startTime])
}

/// Maintenance logs for vehicles
model MaintenanceLog {
  id                String         @id @default(uuid())

  vehicleId         String
  vehicle           Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  // Maintenance details
  type              String         // SERVICE, REPAIR, INSPECTION, BREAKDOWN
  description       String         @db.Text
  cost              Decimal?       @db.Decimal(10, 2)

  // Dates
  startDate         DateTime       @default(now())
  endDate           DateTime?
  completedAt       DateTime?

  // Service center details
  serviceProvider   String?
  serviceProviderPhone String?
  invoiceNumber     String?

  // Status
  status            String         @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED

  // Timestamps
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Performed by
  performedBy       String?        // Admin or technician name
}

/// Configuration and settings
model SystemConfig {
  id                String         @id @default(uuid())
  key               String         @unique
  value             String         @db.Text
  description       String?        @db.Text
  category          String?        // PRICING, BOOKING, PAYMENT, NOTIFICATION, etc.

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

/// Promo codes and discounts
model PromoCode {
  id                String         @id @default(uuid())
  code              String         @unique
  description       String?

  // Discount details
  discountType      String         // PERCENTAGE, FIXED_AMOUNT
  discountValue     Decimal        @db.Decimal(10, 2)
  maxDiscountAmount Decimal?       @db.Decimal(10, 2)
  minBookingAmount  Decimal?       @db.Decimal(10, 2)

  // Applicability
  applicableVehicleTypes String[]   // Empty means all types
  applicableTripTypes String[]      // Empty means all types

  // Validity
  startDate         DateTime
  endDate           DateTime

  // Usage limits
  maxUses           Int?           // null = unlimited
  usedCount         Int            @default(0)
  maxUsesPerUser    Int?           // null = unlimited

  // Status
  isActive          Boolean        @default(true)

  // Timestamps
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relations
  usages            PromoCodeUsage[]
}

/// Promo code usage tracking
model PromoCodeUsage {
  id                String         @id @default(uuid())

  promoCodeId       String
  promoCode         PromoCode      @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  bookingId         String
  customerId        String

  discountApplied   Decimal        @db.Decimal(10, 2)

  createdAt         DateTime       @default(now())

  @@unique([promoCodeId, bookingId])
}
