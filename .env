# Database Configuration - Update with your actual PostgreSQL credentials
DATABASE_URL="postgresql://postgres:....@localhost:5432/vehicle_booking"

# Application Configuration
NODE_ENV="development"
PORT=3001

# JWT Secret for Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production-12345678"

# Payment Gateway Configuration (Optional - add your keys)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""

# Email Configuration (Optional)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM=""

# Admin Configuration
DEFAULT_ADMIN_EMAIL="admin@busbooking.com"
DEFAULT_ADMIN_PASSWORD="Admin@123456"

# CORS Configuration
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"
